<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/linearLayout2"
        android:layout_width="330dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingBottom="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias=".15">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre Completo"
            android:textColor="#0E3E3E"
            android:textSize="13sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="2dp" />

        <EditText
            android:id="@+id/input_nombre_vendedor"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:background="@drawable/bg_input"
            android:backgroundTint="#DFF7E2"
            android:hint="Nombre Completo"
            android:paddingStart="15dp"
            android:textSize="13sp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Correo Electrónico"
            android:textColor="#0E3E3E"
            android:textSize="13sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="2dp" />

        <EditText
            android:id="@+id/input_correo_vendedor"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:background="@drawable/bg_input"
            android:backgroundTint="#DFF7E2"
            android:hint="correo@ejemplo.com"
            android:inputType="textEmailAddress"
            android:paddingStart="15dp"
            android:textSize="13sp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="20dp" />

        <!-- Contraseña -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Contraseña"
            android:textColor="#0E3E3E"
            android:textSize="13sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="2dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/input_contrasena_vendedor"
            android:layout_width="330dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            app:boxBackgroundColor="@android:color/transparent"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="0dp"
            app:endIconMode="password_toggle"
            app:endIconTint="#00D09E"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_contrasena"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/bg_input"
                android:backgroundTint="#DFF7E2"
                android:hint="● ● ● ● ● ● ● ●"
                android:inputType="textPassword"
                android:paddingStart="12dp"
                android:paddingTop="0dp"
                android:paddingEnd="50dp"
                android:paddingBottom="0dp"
                android:textColor="#333"
                android:textColorHint="#888"
                android:textSize="15sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Teléfono"
            android:textColor="#0E3E3E"
            android:textSize="13sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="2dp" />

        <EditText
            android:id="@+id/input_telefono_vendedor"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:background="@drawable/bg_input"
            android:backgroundTint="#DFF7E2"
            android:hint="81 1234 5678"
            android:inputType="phone"
            android:paddingStart="15dp"
            android:textSize="13sp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fecha de Registro"
            android:textColor="#0E3E3E"
            android:textSize="13sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="2dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="0dp"
            app:endIconDrawable="@android:drawable/ic_menu_my_calendar"
            app:endIconMode="custom"
            app:endIconTint="#00D09E"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_fecha_registro"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/bg_input"
                android:backgroundTint="#DFF7E2"
                android:clickable="true"
                android:cursorVisible="false"
                android:focusable="false"
                android:hint="DD / MM / YYYY"
                android:inputType="none"
                android:paddingStart="12dp"
                android:paddingTop="0dp"
                android:paddingEnd="50dp"
                android:paddingBottom="0dp"
                android:textColor="#333"
                android:textColorHint="#888"
                android:textSize="13sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="30dp" />

        <Button
            android:id="@+id/btn_GuardarVendedor"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_gravity="center_horizontal"
            android:backgroundTint="#00D09E"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Guardar Vendedor"
            android:textColor="#052224"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>