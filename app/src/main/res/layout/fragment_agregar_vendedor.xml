<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00D09E">

    <TextView
        android:id="@+id/txtTituloVendedor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Agregar Vendedor"
        android:textColor="#052224"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/zonaBlanca"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.15" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/zonaBlanca"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_menu_redondo_contenido"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideline3">

        <LinearLayout
            android:id="@+id/linearLayout2"
            android:layout_width="330dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="40dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre Completo"
                android:textColor="#0E3E3E"
                android:textSize="13sp"
                android:textStyle="bold" />
            <Space android:layout_width="match_parent" android:layout_height="2dp" />
            <EditText
                android:id="@+id/input_nombre_vendedor"
                android:layout_width="match_parent"
                android:layout_height="35dp"
                android:background="@drawable/bg_input"
                android:backgroundTint="#DFF7E2"
                android:hint="Ej. Juan Pérez"
                android:paddingStart="15dp"
                android:textSize="13sp" />
            <Space android:layout_width="match_parent" android:layout_height="25dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Correo Electrónico"
                android:textColor="#0E3E3E"
                android:textSize="13sp"
                android:textStyle="bold" />
            <Space android:layout_width="match_parent" android:layout_height="2dp" />
            <EditText
                android:id="@+id/input_correo_vendedor"
                android:layout_width="match_parent"
                android:layout_height="35dp"
                android:background="@drawable/bg_input"
                android:backgroundTint="#DFF7E2"
                android:hint="correo@ejemplo.com"
                android:inputType="textEmailAddress"
                android:paddingStart="15dp"
                android:textSize="13sp" />
            <Space android:layout_width="match_parent" android:layout_height="25dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Teléfono"
                android:textColor="#0E3E3E"
                android:textSize="13sp"
                android:textStyle="bold" />
            <Space android:layout_width="match_parent" android:layout_height="2dp" />
            <EditText
                android:id="@+id/input_telefono_vendedor"
                android:layout_width="match_parent"
                android:layout_height="35dp"
                android:background="@drawable/bg_input"
                android:backgroundTint="#DFF7E2"
                android:hint="55 5555 5555"
                android:inputType="phone"
                android:paddingStart="15dp"
                android:textSize="13sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_GuardarVendedor"
            android:layout_width="160dp"
            android:layout_height="35dp"
            android:backgroundTint="#00D09E"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Guardar"
            android:textColor="#052224"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/linearLayout2"
            app:layout_constraintVertical_bias="0.2" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>