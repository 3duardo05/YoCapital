<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
android:layout_width="match_parent"
android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/linearLayout2"
        android:layout_width="330dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="40dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre del Producto"
            android:textColor="#0E3E3E"
            android:textSize="13sp"
            android:textStyle="bold" />
        <Space android:layout_width="match_parent" android:layout_height="2dp" />
        <EditText
            android:id="@+id/input_nombre_producto"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:background="@drawable/bg_input"
            android:backgroundTint="#DFF7E2"
            android:textColor="#333"
            android:textColorHint="#888"
            android:hint="Ej. Llantas, Seguros, etc."
            android:paddingStart="15dp"
            android:textSize="13sp" />
        <Space android:layout_width="match_parent" android:layout_height="25dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Precio"
            android:textColor="#0E3E3E"
            android:textSize="13sp"
            android:textStyle="bold" />
        <Space android:layout_width="match_parent" android:layout_height="2dp" />
        <EditText
            android:id="@+id/input_precio_producto"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:background="@drawable/bg_input"
            android:backgroundTint="#DFF7E2"
            android:hint="$ 0.00"
            android:textColor="#333"
            android:textColorHint="#888"
            android:inputType="numberDecimal"
            android:paddingStart="15dp"
            android:textSize="13sp" />
        <Space android:layout_width="match_parent" android:layout_height="25dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stock (Cantidad disponible)"
            android:textColor="#0E3E3E"
            android:textSize="13sp"
            android:textStyle="bold" />
        <Space android:layout_width="match_parent" android:layout_height="2dp" />

        <EditText
            android:id="@+id/input_stock_producto"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:background="@drawable/bg_input"
            android:backgroundTint="#DFF7E2"
            android:hint="0"
            android:textColor="#333"
            android:textColorHint="#888"
            android:inputType="number"
            android:paddingStart="15dp"
            android:textSize="13sp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="25dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Comisión del Vendedor (%)"
            android:textColor="#0E3E3E"
            android:textSize="13sp"
            android:textStyle="bold" />
        <Space
            android:layout_width="match_parent"
            android:layout_height="2dp" />
        <EditText
            android:id="@+id/input_comision_producto"
            android:layout_width="match_parent"
            android:layout_height="35dp"
            android:background="@drawable/bg_input"
            android:backgroundTint="#DFF7E2"
            android:hint="1%"
            android:textColor="#333"
            android:textColorHint="#888"
            android:inputType="numberDecimal"
            android:paddingStart="15dp"
            android:textSize="13sp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_GuardarProducto"
        android:layout_width="160dp"
        android:layout_height="35dp"
        android:backgroundTint="#00D09E"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="Guardar"
        android:textColor="#052224"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout2"
        app:layout_constraintVertical_bias="0.2" />

</androidx.constraintlayout.widget.ConstraintLayout>