<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00D09E"
    tools:context=".gerente.PerfilGerenteFragment">

    <!-- Saludo -->
    <TextView
        android:id="@+id/txtSaludo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:text="Configuración"
        android:textColor="#052224"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/guideline_inicio_blanco"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ✅ GUIDELINE 1: Inicio de la zona blanca -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_inicio_blanco"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.12" />



    <!-- Zona blanca (anclada al guideline 1) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/zonaBlanca"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_menu_redondo_contenido"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="@id/guideline_inicio_blanco">

        <!-- ✅ GUIDELINE 2: Inicio del contenido dentro de la zona blanca -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_inicio_contenido"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.05" />

        <!-- ScrollView (anclado al guideline 2) -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:paddingBottom="80dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="@id/guideline_inicio_contenido">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Card Información del Perfil -->
                <!-- Card Información del Perfil -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="#FFFFFF"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Título y botón editar -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="👤 Información del Perfil"
                                android:textColor="#052224"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <Button
                                android:id="@+id/btn_editar_perfil"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:backgroundTint="#00D09E"
                                android:text="✏️ Editar"
                                android:textColor="#FFFFFF"
                                android:textSize="12sp"
                                app:cornerRadius="8dp"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nombre"
                            android:textColor="#666666"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/txt_nombre_usuario"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:text="Gerente Principal"
                            android:textColor="#052224"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Correo"
                            android:textColor="#666666"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/txt_correo_usuario"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:text="gerente@yocapital.com"
                            android:textColor="#052224"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Teléfono"
                            android:textColor="#666666"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/txt_telefono_usuario"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="81 1234 5678"
                            android:textColor="#052224"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Card Estadísticas Rápidas -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="#FFFFFF"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            android:text="📊 Estadísticas"
                            android:textColor="#052224"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <!-- Vendedores Activos -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Vendedores activos"
                                android:textColor="#666666"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/txt_total_vendedores"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5"
                                android:textColor="#00D09E"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <!-- Productos en Inventario -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Productos en inventario"
                                android:textColor="#666666"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/txt_total_productos"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12"
                                android:textColor="#00D09E"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <!-- Ventas del año -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Ventas del año"
                                android:textColor="#666666"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/txt_ventas_anio"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$5,440,500"
                                android:textColor="#00D09E"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>


                <!-- Sección Reportes -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="📄 Reportes"
                    android:textColor="#052224"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <!-- Botón Descargar PDF (80%) -->
                    <Button
                        android:id="@+id/btn_descargar_pdf"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="0.8"
                        android:backgroundTint="#00D09E"
                        android:text="📥 Descargar PDF"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        app:cornerRadius="8dp" />

                    <!-- Espaciado entre botones -->
                    <Space
                        android:layout_width="12dp"
                        android:layout_height="1dp" />

                    <!-- Botón Vista Previa (20%) -->
                    <Button
                        android:id="@+id/btn_vista_previa_reporte"
                        android:layout_width="wrap_content"
                        android:layout_height="50dp"
                        android:backgroundTint="#FFFFFF"
                        android:text="👁️ Vista Previa"
                        android:textColor="#052224"
                        android:textSize="14sp"
                        app:cornerRadius="8dp"
                        app:strokeColor="#00D09E"
                        app:strokeWidth="2dp" />

                </LinearLayout>

                <!-- Botón Cerrar Sesión -->
                <Button
                    android:id="@+id/btn_cerrar_sesion"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="32dp"
                    android:backgroundTint="#FF5252"
                    android:text="🚪 Cerrar Sesión"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="8dp" />

            </LinearLayout>

        </ScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>